/' ========================================================================================
   1. ENTITY RELATIONSHIP DIAGRAM (ERD) - DATABASE SCHEMA
   ======================================================================================== '/

@startuml ERD_Database_Schema
!define ENTITY_COLOR #FFE5CC
!define ATTRIBUTE_COLOR #FFFFCC
!define KEY_COLOR #FFD700

title Entity Relationship Diagram - Database Schema

entity "User" as User #FFE5CC {
    * **_id** : ObjectId <<KEY>>
    --
    * email : String <<UNIQUE>>
    * password_hash : String
    full_name : String
    created_at : DateTime
    updated_at : DateTime
}

entity "StudentProfile" as StudentProfile #FFE5CC {
    * **_id** : ObjectId <<KEY>>
    --
    * user_id : ObjectId <<FK>>
    gpa : Float
    python_experience : String
    sql_experience : String
    java_experience : String
    interested_domain : String
    completed_onboarding : Boolean
    created_at : DateTime
    updated_at : DateTime
}

entity "CareerPrediction" as CareerPrediction #FFE5CC {
    * **_id** : ObjectId <<KEY>>
    --
    * user_id : ObjectId <<FK>>
    predicted_career : String
    prediction_score : Float
    skill_scores : JSON
    learning_plan : JSON
    prediction_date : DateTime
    is_active : Boolean
}

entity "ChatMessage" as ChatMessage #FFE5CC {
    * **_id** : ObjectId <<KEY>>
    --
    * user_id : ObjectId <<FK>>
    * prediction_id : ObjectId <<FK>>
    role : String (user/assistant)
    content : String
    timestamp : DateTime
    message_order : Integer
}

entity "LearningProgress" as LearningProgress #FFE5CC {
    * **_id** : ObjectId <<KEY>>
    --
    * user_id : ObjectId <<FK>>
    * prediction_id : ObjectId <<FK>>
    skill_name : String
    week_number : Integer
    lesson_completed : Boolean
    quiz_score : Float
    notes : String
    last_updated : DateTime
}

entity "Feedback" as Feedback #FFE5CC {
    * **_id** : ObjectId <<KEY>>
    --
    user_email : String
    rating : Integer (1-5)
    comment : String
    created_at : DateTime
}

entity "KnowledgeBase" as KnowledgeBase #FFE5CC {
    * **_id** : ObjectId <<KEY>>
    --
    * user_id : ObjectId <<FK>>
    content : String
    source : String
    embedding : Vector
    chunk_index : Integer
    created_at : DateTime
}

entity "LessonContent" as LessonContent #FFE5CC {
    * **_id** : ObjectId <<KEY>>
    --
    * career_name : String
    skill_name : String
    week_number : Integer
    title : String
    content : String
    resources : String[]
    difficulty : String (beginner/intermediate/advanced)
}

entity "Quiz" as Quiz #FFE5CC {
    * **_id** : ObjectId <<KEY>>
    --
    * skill_name : String
    questions : JSON[]
    difficulty : String
    passing_score : Integer
    created_at : DateTime
}

User ||--o{ StudentProfile : "has"
User ||--o{ CareerPrediction : "creates"
User ||--o{ ChatMessage : "sends"
User ||--o{ LearningProgress : "tracks"
User ||--o{ KnowledgeBase : "uploads"
CareerPrediction ||--o{ ChatMessage : "associates"
CareerPrediction ||--o{ LearningProgress : "defines"
LessonContent ||--o{ LearningProgress : "references"
Quiz ||--o{ LearningProgress : "tests"

@enduml


/' ========================================================================================
   2. EXTENDED ENTITY RELATIONSHIP DIAGRAM (EERD) - WITH INHERITANCE & CONSTRAINTS
   ======================================================================================== '/

@startuml EERD_Extended
!define SUPERTYPE_COLOR #E1F5FF
!define SUBTYPE_COLOR #B3E5FC
!define WEAK_ENTITY_COLOR #FFF9C4

title Extended Entity Relationship Diagram (EERD)

entity "User (Supertype)" as User <<SUPERTYPE>> #E1F5FF {
    * **_id** : ObjectId <<KEY>>
    --
    * email : String
    * password_hash : String
    full_name : String
    created_at : DateTime
    user_type : Enum(student/admin)
    status : Enum(active/inactive)
}

entity "Student" as Student <<SUBTYPE>> #B3E5FC {
    * student_id : ObjectId
    --
    major : String
    year_of_study : Integer
    admission_date : DateTime
}

entity "Administrator" as Admin <<SUBTYPE>> #B3E5FC {
    * admin_id : ObjectId
    --
    admin_level : Integer
    department : String
    permissions : String[]
}

entity "StudentProfile" as StudentProfile #FFFFCC {
    * **_id** : ObjectId <<KEY>>
    --
    * user_id : ObjectId <<FK>>
    gpa : Float (0.0-4.0)
    python_exp : Enum
    sql_exp : Enum
    java_exp : Enum
    interested_domain : String
}

entity "CareerPrediction" as CareerPrediction #FFFFCC {
    * **_id** : ObjectId <<KEY>>
    --
    * user_id : ObjectId <<FK>>
    predicted_career : String (NOT NULL)
    confidence_score : Float (0.0-1.0)
    explanation : String
    created_at : DateTime
}

entity "LearningPlan" as LearningPlan <<WEAK>> #FFF9C4 {
    * **_id** : ObjectId <<KEY>>
    --
    * prediction_id : ObjectId <<FK>>
    beginner_path : String
    intermediate_path : String
    advanced_path : String
    projects : String[]
    tools : String[]
    estimated_duration : Integer (weeks)
}

entity "ConversationSession" as ConversationSession #FFFFCC {
    * **_id** : ObjectId <<KEY>>
    --
    * user_id : ObjectId <<FK>>
    * prediction_id : ObjectId <<FK>>
    session_start : DateTime
    session_end : DateTime
    total_messages : Integer
    context : JSON
    status : Enum(active/closed)
}

entity "ChatMessage" as ChatMessage <<WEAK>> #FFF9C4 {
    * **_id** : ObjectId <<KEY>>
    --
    * session_id : ObjectId <<FK>>
    role : Enum(user/assistant)
    content : String
    timestamp : DateTime
    token_count : Integer
}

entity "KnowledgeDocument" as KnowledgeDocument #FFFFCC {
    * **_id** : ObjectId <<KEY>>
    --
    * user_id : ObjectId <<FK>>
    document_type : Enum(pdf/txt/web)
    source : String
    chunks : DocumentChunk[]
    metadata : JSON
    indexed_at : DateTime
}

entity "DocumentChunk" as DocumentChunk <<WEAK>> #FFF9C4 {
    * chunk_id : String
    --
    * doc_id : ObjectId <<FK>>
    content : String
    embedding : Vector
    position : Integer
}

User --|{ Student : specializes
User --|{ Admin : specializes
Student ||--o{ StudentProfile : "maintains"
Student ||--o{ CareerPrediction : "receives"
CareerPrediction ||--|| LearningPlan : "generates"
Student ||--o{ ConversationSession : "initiates"
ConversationSession ||--o{ ChatMessage : "contains"
Student ||--o{ KnowledgeDocument : "uploads"
KnowledgeDocument ||--o{ DocumentChunk : "consists_of"

note right of User
  Generalization/Specialization
  User is supertype with Student
  and Admin subtypes
end note

note right of LearningPlan
  Weak Entity - depends on
  CareerPrediction for existence
end note

@enduml


