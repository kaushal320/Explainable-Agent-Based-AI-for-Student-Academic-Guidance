@startuml StateDiagram_UserJourney
title State Diagram - Student User Journey

[*] --> Unauthenticated

state "Unauthenticated" as Unauth {
    [*] --> ViewHome
    ViewHome --> ViewFeedback: Navigate
    ViewFeedback --> ViewLearning: Navigate
    ViewLearning --> ViewRoadmap: Navigate
    ViewRoadmap --> AuthChoice: Click Login
}

AuthChoice: Show Auth Modal

AuthChoice --> Register: Choose Register
AuthChoice --> Login: Choose Login

state "Authentication" as Auth {
    Register: Submit Registration
    Register --> ValidateReg: Validate Input
    ValidateReg --> [Register Error]: Invalid Input
    [Register Error] --> Register
    ValidateReg --> CreateAccount: Valid
    CreateAccount --> AuthSuccess: Account Created
    
    Login: Submit Login
    Login --> ValidateLogin: Validate Credentials
    ValidateLogin --> [Login Error]: Invalid
    [Login Error] --> Login
    ValidateLogin --> AuthSuccess: Valid
}

AuthSuccess --> Authenticated

state "Authenticated" as Auth2 {
    state "Onboarded" as Onb {
        [*] --> Onboarding
        Onboarding --> SubmitProfile: Fill Form
        SubmitProfile --> ProfileSuccess: Saved
        ProfileSuccess --> [*]
    }
    
    state "Main Application" as Main {
        [*] --> Dashboard
        Dashboard --> ViewPrediction: Get Prediction
        ViewPrediction --> ViewExplanation: Read XAI
        ViewExplanation --> Chat: Ask Questions
        Chat --> Chat: Continue Conversation
        Chat --> Learning: Access Learning
        Learning --> LessonView: View Lessons
        LessonView --> TakeQuiz: Take Quiz
        TakeQuiz --> ViewProgress: Check Progress
        ViewProgress --> Chat: Ask More Questions
        LessonView --> Feedback: Submit Feedback
        Feedback --> ViewProgress
    }
    
    Onb --> Main: Onboarding Complete
    Main --> [*]
}

Authenticated --> Logout: User Logout

Logout --> Unauthenticated

note right of Unauth
  Public pages available
  No auth required
end note

note right of Auth
  Registration & Login
  JWT token generation
  Session management
end note

note right of Onb
  First-time user flow
  Profile creation
end note

note right of Main
  Full application access
  Prediction, Chat,
  Learning Hub
end note

@enduml

