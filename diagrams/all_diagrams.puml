/' ========================================================================================
   10. SEQUENCE DIAGRAM - CAREER PREDICTION FLOW
   ======================================================================================== '/

@startuml Sequence_CareerPrediction
title Sequence Diagram - Career Prediction Flow

actor Student
participant "React UI" as UI
participant "FastAPI" as API
participant "PredictionService" as PredService
participant "ML Models" as MLModels
participant "GroqAPI" as Groq
participant "MongoDB" as DB

Student -> UI: Submit Onboarding Data\n(GPA, Skills, Domain)
UI -> API: POST /api/predict\n(StudentOnboarding)
API -> PredService: predict_career()

PredService -> PredService: Transform Features\n(exp_mapping, calculations)
PredService -> MLModels: Load encoders\nTransform domain

MLModels -> PredService: domain_encoded

PredService -> MLModels: Load classifier model\nPredict career

MLModels -> PredService: prediction_array\ncareer_class

PredService -> PredService: Inverse transform\ncareer name

PredService -> PredService: Analyze Weaknesses\n(skill_gaps)

PredService -> Groq: Generate Explanation\nPrompt: Why this career?

Groq -> Groq: LLM Inference\n(LLaMA model)

Groq -> PredService: Explanation Text

PredService -> DB: Get learning plan\ntemplate for career

DB -> PredService: Career content\n(beginner, intermediate, advanced)

PredService -> PredService: Build LearningPlan\nobject

PredService -> API: Return PredictionResponse

API -> UI: {\n  career: "Data Scientist",\n  plan: {...},\n  skills: {...}\n}

UI -> UI: Update Redux State\nDisplay Prediction

UI -> Student: Show Career + Explanation\nRendered Learning Plan

@enduml


/' ========================================================================================
   11. SEQUENCE DIAGRAM - CHAT/TUTORING FLOW
   ======================================================================================== '/

@startuml Sequence_ChatTutoring
title Sequence Diagram - Chat/Tutoring Agent Flow

actor Student
participant "React UI" as UI
participant "FastAPI" as API
participant "ChatService" as ChatSvc
participant "RAGService" as RAGSvc
participant "VectorStore" as VectorStore
participant "Groq LLM" as Groq
participant "MongoDB" as DB

Student -> UI: Type Chat Query\n"How do I learn Python?"

UI -> UI: Format ChatRequest\n(message, history, context)

UI -> API: POST /api/chat/stream\n(ChatRequest)

API -> ChatSvc: get_streaming_response()

ChatSvc -> DB: Retrieve user context\n(prediction, progress)

DB -> ChatSvc: Career + Learning context

ChatSvc -> RAGSvc: retrieve_documents(query)

RAGSvc -> RAGSvc: Embed query vector

RAGSvc -> VectorStore: Similarity search\n(cosine similarity)

VectorStore -> RAGSvc: Top-K relevant docs

RAGSvc -> ChatSvc: Retrieved knowledge\nchunks + metadata

ChatSvc -> ChatSvc: Build system prompt\nwith tutor personality\n+ context + retrieved_docs

ChatSvc -> Groq: Streaming request\nwith complete prompt

Groq -> Groq: Stream LLM tokens\n(real-time)

Groq -> ChatSvc: text_chunk_1
Groq -> ChatSvc: text_chunk_2
Groq -> ChatSvc: text_chunk_3
Groq -> ChatSvc: [EOS]

ChatSvc -> UI: Stream chunks\n(Server-Sent Events)

UI -> UI: Render text\nreal-time streaming

UI -> Student: "Python is a versatile...\n(streaming in real-time)"

ChatSvc -> DB: Store completed message\n(user + assistant)

DB -> ChatSvc: ack

@enduml


/' ========================================================================================
   12. AUTHENTICATION & AUTHORIZATION FLOW
   ======================================================================================== '/

@startuml Sequence_Authentication
title Sequence Diagram - User Authentication & Authorization

actor Student as S
participant "React Frontend" as FE
participant "FastAPI AuthRouter" as Router
participant "AuthService" as AuthSvc
participant "MongoDB Users" as UserDB
participant "JWT Handler" as JWT

S -> FE: Enter email + password\n+ Register/Login

alt Registration Flow
    FE -> Router: POST /auth/register\n{email, password, full_name}
    Router -> AuthSvc: register(UserCreate)
    
    AuthSvc -> UserDB: Check if email exists
    UserDB -> AuthSvc: Email exists? (error)\nOr empty (OK)
    
    AuthSvc -> AuthSvc: hash_password(password)\n(PBKDF2-SHA256)
    
    AuthSvc -> UserDB: INSERT new user\n{email, password_hash, full_name, created_at}
    UserDB -> AuthSvc: inserted_id
    
    AuthSvc -> JWT: create_access_token\n{sub: email, uid: user_id}
    JWT -> AuthSvc: access_token (JWT)
    
    AuthSvc -> Router: AuthResponse\n{token, user}
    Router -> FE: {access_token, user}
    
    FE -> FE: localStorage.setItem\n(TOKEN_KEY, access_token)
    FE -> S: "Registration successful!\nRedirect to onboarding"
else Login Flow
    FE -> Router: POST /auth/login\n{email, password}
    Router -> AuthSvc: login(UserLogin)
    
    AuthSvc -> UserDB: find user by email
    UserDB -> AuthSvc: user_document\n(or not found)
    
    AuthSvc -> AuthSvc: verify_password\n(plain, hashed)
    
    AuthSvc -> JWT: create_access_token\n{sub: email, uid: user_id}
    JWT -> AuthSvc: access_token
    
    AuthSvc -> Router: AuthResponse
    Router -> FE: {access_token, user}
    
    FE -> FE: localStorage.setItem\n(TOKEN_KEY, access_token)
    FE -> S: "Login successful!\nRedirect to app"
end

note right of FE
  Protected Endpoints:
  Every request includes:
  Authorization: Bearer {token}
end note

S -> FE: Access protected feature\n(e.g., prediction)

FE -> FE: Retrieve token\nfrom localStorage

FE -> Router: POST /api/predict\nHeaders: {Authorization: Bearer token}

Router -> Router: Extract JWT from header

Router -> AuthSvc: get_current_user(token)

AuthSvc -> JWT: decode JWT\n(verify signature)

JWT -> AuthSvc: {sub: email, uid, exp}

AuthSvc -> UserDB: find user by email

UserDB -> AuthSvc: user_document

AuthSvc -> Router: user_document (OK)\nor raise 401 Unauthorized

Router -> Router: proceed with request\n(user available)

Router -> S: Process and return

@enduml


