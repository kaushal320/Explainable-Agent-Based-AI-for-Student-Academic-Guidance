@startuml Deployment_Infrastructure
title Production Deployment Architecture - Cloud Infrastructure

node "User's Device" #E3F2FD {
    component "Web Browser\n(Chrome/Safari/Firefox)" as Browser
}

cloud "Cloud Provider (AWS/GCP/Azure)" {
    
    node "Frontend Static Hosting" #STATE_COLOR {
        component "CDN (CloudFront/Cloudflare)" as CDN
        component "S3 Bucket\n(Vite Build Artifacts)" as S3
    }
    
    node "Application Cluster (Docker / K8s)" #BACKEND_COLOR {
        component "Nginx Container\n(Reverse Proxy)" as Nginx
        
        package "FastAPI App Nodes" {
            component "API Instance 1" as API1
            component "API Instance 2" as API2
        }
    }
    
    node "Managed Data Services" #DATA_COLOR {
        database "MongoDB Atlas\n(Replica Set)" as Mongo
        database "Redis Managed\n(Cache/Session)" as Redis
        database "Vector Search Index" as VectorDB
    }
}

node "AI Ecosystem (SaaS)" #AI_COLOR {
    component "Groq Cloud API" as Groq
    component "Stripe Billing" as Stripe
    component "SendGrid SMTP" as SendGrid
}

' Connections
Browser --> CDN : HTTPS (Port 443)
CDN --> S3 : fetch static assets
Browser --> Nginx : API Calls
Nginx --> API1 : Load Balance (8000)
Nginx --> API2 : Load Balance (8000)

API1 --> Mongo : CRUD
API1 --> Redis : Cache hit/miss
API1 --> VectorDB : RAG Query

API1 --> Groq : LLM Inference
API1 --> Stripe : Payment Webhooks
API1 --> SendGrid : Transactional Emails

@enduml
