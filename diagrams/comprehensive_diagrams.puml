title User Journey - State Transitions

[*] --> Unauthenticated

state Unauthenticated {
  [*] --> ViewHome
  ViewHome --> ViewLearning: Browse
  ViewLearning --> ViewFeedback: Browse
}

Unauthenticated --> Authentication: Click Login

state Authentication {
  [*] --> AuthChoice
  AuthChoice --> Register: Choose Register
  AuthChoice --> SignIn: Choose Login
  Register --> CreateAccount: Submit
  SignIn --> VerifyAccount: Submit
  CreateAccount --> AuthSuccess: Success
  VerifyAccount --> AuthSuccess: Success
}

Authentication --> Authenticated: Token Generated

state Authenticated {
  [*] --> OnboardingCheck
  OnboardingCheck --> Onboarding: First Time
  OnboardingCheck --> Dashboard: Returning
  
  state Onboarding {
    [*] --> FillProfile
    FillProfile --> SubmitProfile: Submit
    SubmitProfile --> [*]
  }
  
  state Dashboard {
    [*] --> MainView
    MainView --> ViewPrediction: Click
    ViewPrediction --> ChatOption: Read
    ChatOption --> TutoringChat: Engage
    TutoringChat --> LearningAccess: Continue
    LearningAccess --> ProgressView: Check
  }
}

Authenticated --> Unauthenticated: Logout

