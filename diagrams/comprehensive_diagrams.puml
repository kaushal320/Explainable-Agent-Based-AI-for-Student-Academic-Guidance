/' ========== 23. SECURITY FLOW ========== '/

@startuml Security
title Security - Authentication & Authorization

actor User as U
participant API as A
participant AuthMiddleware as AM
participant JWT as J
participant RoleCheck as RC

U -> A: Request with Token

A -> AM: Extract Token
AM -> J: Decode & Verify
J -> AM: Token Valid?

alt Valid
  AM -> RC: Check Permissions
  RC -> RC: User Role
  
  alt Authorized
    RC -> A: Proceed
    A -> A: Process
    A -> U: Success Response
  else Not Authorized
    RC -> A: Forbidden
    A -> U: 403 Forbidden
  end
else Invalid
  AM -> U: 401 Unauthorized
end

@enduml


