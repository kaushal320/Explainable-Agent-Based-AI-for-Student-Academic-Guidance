/' ========== 8. AUTHENTICATION SEQUENCE ========== '/

@startuml AuthFlow
title Authentication & Authorization Flow

participant User as U
participant UI as "React"
participant Router as "FastAPI Router"
participant AuthService as "Auth Service"
participant JWT as "JWT Handler"
participant MongoDB as "DB"

U -> UI: Enter Credentials
UI -> Router: POST /register or /login

alt Register Path
  Router -> AuthService: register(UserCreate)
  AuthService -> AuthService: Hash Password
  AuthService -> MongoDB: Create User
  MongoDB -> AuthService: User Created
  AuthService -> JWT: Generate Token
  JWT -> AuthService: JWT Token
  AuthService -> Router: AuthResponse
  Router -> UI: Token + User
  UI -> UI: localStorage.setItem
else Login Path
  Router -> AuthService: login(UserLogin)
  AuthService -> MongoDB: Find User
  MongoDB -> AuthService: User Data
  AuthService -> AuthService: Verify Password
  AuthService -> JWT: Generate Token
  JWT -> AuthService: JWT Token
  AuthService -> Router: AuthResponse
  Router -> UI: Token + User
  UI -> UI: localStorage.setItem
end

U -> UI: Access Protected Resource
UI -> UI: Get Token
UI -> Router: Request + Bearer Token
Router -> JWT: Decode Token
JWT -> Router: Decoded Payload
Router -> MongoDB: Get User
MongoDB -> Router: User Data
Router -> UI: Return Data

@enduml


