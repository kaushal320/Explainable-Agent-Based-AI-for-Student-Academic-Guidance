/' ========== 17. ERROR HANDLING FLOW ========== '/

@startuml ErrorHandling
title Error Handling & Recovery Flow

actor User as U
participant System as S
participant ErrorHandler as E
participant Logger as L
participant Database as D

U -> S: Request
alt Success Path
  S -> D: Operation
  D -> S: Success
  S -> U: Response
else Error Path
  S -> E: Catch Exception
  E -> L: Log Error
  L -> L: Record Details
  E -> E: Determine Type
  
  alt Validation Error
    E -> U: 400 Bad Request
  else Not Found
    E -> U: 404 Not Found
  else Server Error
    E -> U: 500 Server Error
  else Auth Error
    E -> U: 401 Unauthorized
  end
end

@enduml


/' ========== 18. CACHING STRATEGY ========== '/

@startuml Caching
title Caching Strategy - Performance Optimization

actor Client as C
participant API as A
participant Cache as CA
database Database as DB

C -> A: Request
A -> CA: Check Cache

alt Cache Hit
  CA -> A: Return Cached Data
  A -> C: Response (Fast)
else Cache Miss
  A -> DB: Query
  DB -> A: Data
  A -> CA: Store in Cache
  A -> C: Response
end

note right of CA
  Cache Invalidation:
  - TTL: 1 hour
  - Events: User update
  - Manual: Admin clear
end note

@enduml


