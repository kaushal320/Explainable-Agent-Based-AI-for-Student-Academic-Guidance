/' ========== 1. ENTITY RELATIONSHIP DIAGRAM ========== '/

@startuml ERD_Database_Complete
title ERD - Complete Database Schema

entity User {
  *_id : ObjectId
  --
  *email : String
  *password_hash : String
  full_name : String
  user_type : Enum
  status : Enum
  created_at : DateTime
  updated_at : DateTime
}

entity StudentProfile {
  *_id : ObjectId
  *user_id : ObjectId FK
  --
  gpa : Float
  python_exp : String
  sql_exp : String
  java_exp : String
  domain : String
  onboarding_complete : Boolean
}

entity CareerPrediction {
  *_id : ObjectId
  *user_id : ObjectId FK
  --
  predicted_career : String
  confidence_score : Float
  explanation : String
  created_at : DateTime
  is_active : Boolean
}

entity LearningPlan {
  *_id : ObjectId
  *prediction_id : ObjectId FK
  --
  beginner_path : String
  intermediate_path : String
  advanced_path : String
  projects : Array
  tools : Array
  duration_weeks : Integer
}

entity ChatSession {
  *_id : ObjectId
  *user_id : ObjectId FK
  *prediction_id : ObjectId FK
  --
  session_start : DateTime
  session_end : DateTime
  total_messages : Integer
  status : Enum
}

entity ChatMessage {
  *_id : ObjectId
  *session_id : ObjectId FK
  --
  role : Enum
  content : String
  timestamp : DateTime
  token_count : Integer
}

entity LearningProgress {
  *_id : ObjectId
  *user_id : ObjectId FK
  *prediction_id : ObjectId FK
  --
  skill_name : String
  week_number : Integer
  lesson_completed : Boolean
  quiz_score : Float
  last_updated : DateTime
}

entity KnowledgeDocument {
  *_id : ObjectId
  *user_id : ObjectId FK
  --
  document_type : Enum
  source : String
  chunks : Integer
  metadata : JSON
  indexed_at : DateTime
}

entity DocumentChunk {
  *_id : ObjectId
  *doc_id : ObjectId FK
  --
  chunk_text : String
  embedding : Vector
  position : Integer
}

entity Feedback {
  *_id : ObjectId
  --
  user_email : String
  rating : Integer
  comment : String
  created_at : DateTime
}

entity LessonContent {
  *_id : ObjectId
  --
  career_name : String
  skill_name : String
  week_number : Integer
  title : String
  content : String
  resources : Array
  difficulty : Enum
}

entity Quiz {
  *_id : ObjectId
  --
  skill_name : String
  questions : Array
  difficulty : Enum
  passing_score : Integer
}

User ||--o{ StudentProfile : "has"
User ||--o{ CareerPrediction : "creates"
User ||--o{ ChatSession : "initiates"
User ||--o{ LearningProgress : "tracks"
User ||--o{ KnowledgeDocument : "uploads"
CareerPrediction ||--|| LearningPlan : "generates"
CareerPrediction ||--o{ ChatSession : "associates"
CareerPrediction ||--o{ LearningProgress : "defines"
ChatSession ||--o{ ChatMessage : "contains"
KnowledgeDocument ||--o{ DocumentChunk : "chunks"
LessonContent ||--o{ LearningProgress : "teaches"

@enduml


